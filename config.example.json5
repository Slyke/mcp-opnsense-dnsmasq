// Copy to data/config.json5 for local use. Environment variables override these values.
// Do not commit real config.json5 files with secrets.
{
  http: {
    enabled: true,
    host: "0.0.0.0",
    port: 3000,
  },

  https: {
    enabled: false,
    host: "0.0.0.0",
    port: 3443,
  },

  auth: {
    // Named MCP bearer tokens. readBearerTokens can call read-only tools only.
    readBearerTokens: [
      { name: "reader1", token: "replace-read-token" },
    ],
    readWriteBearerTokens: [
      { name: "admin1", token: "replace-readwrite-token" },
    ],
    healthchecks: false,
  },

  opnsense: {
    baseUrl: "https://opnsense.lan",
    apiKey: "replace-opnsense-api-key",
    apiSecret: "replace-opnsense-api-secret",
    timeoutMs: 10000,
    tlsRejectUnauthorized: true,
  },

  history: {
    file: "./data/history.jsonl",
    count: 50,
    recordReads: false,
  },

  certsDir: "./data/certs",
  readyCheckOpnsense: false,

  defaultInterface: "LAN",
  defaultInterfaceKey: "lan",

  // Set these before applying DHCP reservation writes.
  allowedStaticDhcpCidrs: ["192.168.1.0/24"],
  protectedIps: ["192.168.1.1", "192.168.1.254"],
  excludedIpRanges: [],
  dynamicDhcpRanges: [],
  rejectStaticInsideDynamicRange: false,

  strictHostname: false,
  autoReconfigureAfterWrite: true,
  includeRawDefault: false,

  maxPingCount: 5,
  maxPingPacketSize: 128,

  logging: {
    sinks: {
      console: {
        enabled: true,
        format: "json",
        levels: ["info", "warn", "error"],
      },
      file: {
        enabled: false,
        format: "json",
        path: "./logs/app.jsonl",
        levels: ["warn", "error"],
      },
      http: {
        enabled: false,
        format: "json",
        url: "",
        method: "POST",
        timeoutMs: 2500,
        levels: ["error"],
      },
      syslog: {
        enabled: false,
        format: "json",
        protocol: "udp",
        host: "localhost",
        port: 514,
        facility: "local0",
        appName: "mcp-opnsense-dnsmasq",
        msgId: "app-log",
        levels: ["warn", "error"],
      },
    },
    gates: {
      SERVICE_BOOT_DIAGNOSTICS: {
        level: "info",
        console: true,
      },
      MCP_TOOL_CALL: {
        level: "info",
        console: true,
      },
      OPNSENSE_API_REQUEST: {
        level: "debug",
        console: false,
      },
      OPNSENSE_API_RESPONSE: {
        level: "debug",
        console: false,
      },
    },
  },
}
