# Copy to .env for local testing. Do not commit real .env files.

# Named MCP bearer tokens. read tokens can call read-only tools only.
MCP_READ_BEARER_TOKENS=[{name:"reader1",token:"replace-read-token"}]
MCP_READWRITE_BEARER_TOKENS=[{name:"admin1",token:"replace-readwrite-token"}]

# OPNsense API credentials. The API key is the Basic Auth username;
# the API secret is the Basic Auth password.
OPNSENSE_BASE_URL=https://opnsense.lan
OPNSENSE_API_KEY=replace-opnsense-api-key
OPNSENSE_API_SECRET=replace-opnsense-api-secret
OPNSENSE_TIMEOUT_MS=10000
OPNSENSE_TLS_REJECT_UNAUTHORIZED=true

# Listener settings. At least one of HTTP_ENABLED or HTTPS_ENABLED must be true.
HTTP_ENABLED=true
HTTP_HOST=0.0.0.0
HTTP_PORT=3000
HTTPS_ENABLED=false
HTTPS_HOST=0.0.0.0
HTTPS_PORT=3443
CERTS_DIR=./data/certs

# Runtime behavior.
CONFIG_FILE=./data/config.json5
HISTORY_FILE=./data/history.jsonl
HISTORY_COUNT=50
HISTORY_RECORD_READS=false
READY_CHECK_OPNSENSE=false
AUTH_HEALTHCHECKS=false
AUTO_RECONFIGURE_AFTER_WRITE=true
INCLUDE_RAW_DEFAULT=false

# DHCP guardrails. Set these for your LAN before applying writes.
DEFAULT_INTERFACE=LAN
DEFAULT_INTERFACE_KEY=lan
ALLOWED_STATIC_DHCP_CIDRS=192.168.1.0/24
PROTECTED_IPS=192.168.1.1,192.168.1.254
EXCLUDED_IP_RANGES=
DYNAMIC_DHCP_RANGES=
REJECT_STATIC_INSIDE_DYNAMIC_RANGE=false
STRICT_HOSTNAME=false

# Router ping bounds.
MAX_PING_COUNT=5
MAX_PING_PACKET_SIZE=128

# Logging.
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_FORMAT=json
LOG_CONSOLE_LEVELS=info,warn,error
LOG_FILE_ENABLED=false
LOG_FILE_FORMAT=json
LOG_FILE_PATH=./logs/app.jsonl
LOG_FILE_LEVELS=warn,error
